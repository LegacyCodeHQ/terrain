{
  "name": "terrain",
  "productName": "Terrain",
  "version": "0.1.0",
  "description": "Zoomable sunburst of a git repo's directory structure, sized by file count.",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "test": "jest",
    "test:main": "jest --selectProjects main",
    "test:renderer": "jest --selectProjects renderer",
    "setup:hooks": "git config core.hooksPath .githooks",
    "prepare": "git rev-parse --git-dir >/dev/null 2>&1 && npm run setup:hooks --silent || true"
  },
  "author": {
    "name": "Ragunath Jawahar",
    "email": "ragunath@legacycode.com"
  },
  "license": "Apache-2.0",
  "devDependencies": {
    "@biomejs/biome": "2.4.2",
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/d3": "^7.4.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "electron": "40.4.1",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "~5.6.0",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
